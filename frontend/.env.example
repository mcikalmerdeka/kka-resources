# =============================================================================
# KKA Resources Frontend - Environment Variables (Example)
# =============================================================================
# 1. Copy this file and rename it to `.env.local`
# 2. Replace the placeholder values below with your actual URLs and keys
# 3. NEVER commit the `.env.local` file to version control
# =============================================================================

# ------------------------------------------------------------------------------
# Backend API URL (REQUIRED)
# ------------------------------------------------------------------------------
# The base URL of the KKA Resources backend.
# Use localhost during development, and the Cloud Run URL in production.
NEXT_PUBLIC_API_URL=https://your-backend-url.run.app

# ------------------------------------------------------------------------------
# Frontend API Key (REQUIRED)
# ------------------------------------------------------------------------------
# This must match the API_KEY value set in the backend .env file.
# It is sent in the x-api-key header with every request.
NEXT_PUBLIC_API_KEY=your-strong-secret-key-here

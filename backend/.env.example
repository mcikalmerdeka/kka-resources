# =============================================================================
# KKA Resources Backend - Environment Variables (Example)
# =============================================================================
# 1. Copy this file and rename it to `.env`
# 2. Replace the placeholder values below with your actual keys
# 3. NEVER commit the `.env` file to version control
# =============================================================================

# ------------------------------------------------------------------------------
# Google Cloud Project (for deployment)
# ------------------------------------------------------------------------------
# Your GCP project ID. Find it in your Google Cloud Console or by running:
#   gcloud projects list
GOOGLE_PROJECT_ID=your-gcp-project-id

# ------------------------------------------------------------------------------
# OpenAI API Key (REQUIRED)
# ------------------------------------------------------------------------------
# Get your key from: https://platform.openai.com/api-keys
# This key is used by the chat endpoints to call OpenAI models.
OPENAI_API_KEY=sk-...

# ------------------------------------------------------------------------------
# Tavily Search API Key (REQUIRED for web search feature)
# ------------------------------------------------------------------------------
# Get your key from: https://app.tavily.com/home
# Used by the chatbot's web-search capability (use_search=true).
TAVILY_API_KEY=tvly-...

# ------------------------------------------------------------------------------
# Backend API Key (REQUIRED for API authentication)
# ------------------------------------------------------------------------------
# This is the secret key that the frontend (or any client) must send in the
# x-api-key header to access protected endpoints.
# Change this to a strong random string in production!
API_KEY=your-strong-secret-key-here

# ------------------------------------------------------------------------------
# Backend API URL (used by deploy scripts / external references)
# ------------------------------------------------------------------------------
# The public URL where this backend is deployed.
# Update this after your first successful Cloud Run deployment.
BACKEND_API_URL=https://your-service-url.run.app
